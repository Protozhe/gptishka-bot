BOT_TOKEN=123456:replace_me
# Comma-separated Telegram numeric IDs, e.g. "123,456"
ADMIN_IDS=123

# DB file path (relative or absolute)
DB_PATH=bot.db

# Timezone for displaying dates; if ZoneInfo can't load, bot will fall back to UTC.
TZ=Europe/Moscow

# Reminders
REMIND_BEFORE_DAYS=1
REMIND_CHECK_INTERVAL_SEC=600
REMIND_SEND_TIME_LOCAL=12:00

# Lava placeholders (wire later)
LAVA_PAYMENT_URL_TEMPLATE=
LAVA_WEBHOOK_SECRET=

# Web admin panel
ADMIN_WEB_HOST=0.0.0.0
ADMIN_WEB_PORT=8080
ADMIN_WEB_LOGIN=admin
ADMIN_WEB_PASSWORD=change_me
ADMIN_WEB_SECRET=change_me_too
